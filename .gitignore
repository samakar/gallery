.claude/settings.local.json

# Dependencies
node_modules/

# Build output
dist/
.vite/
tsconfig.tsbuildinfo

# Duplicate of vite.config.ts (.ts is canonical)
vite.config.js

# Local environment (recreate from .env.example)
.env
.env.local

# Local SQLite -- regenerable via `npm run prisma:migrate -- --name init && npm run db:seed`
prisma/dev.db
prisma/dev.db-journal

# Runtime artifacts -- encrypted Master ciphertexts (per-image AES-256-GCM
# bytes persisted by arweave_master.persistEncryptedMasterLocal, required at
# runtime for /v1/deeds/:imageId/download-master), plus any other dev-time
# scratch the platform writes here. Regenerable: re-run runImageOps for any
# image whose ciphertext is missing.
data/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Generated test fixtures -- regenerable via `npx tsx fixtures/build.ts`
fixtures/**/*.jpg
fixtures/**/*.png

# Hand-collected fixtures (phone photos with real EXIF) -- committed
!fixtures/cloudinary/PXL_*.jpg
