# Encrypted Master ciphertexts -- per-image AES-256-GCM bytes persisted by
# arweave_master.persistEncryptedMasterLocal. Required at runtime for
# /v1/deeds/:imageId/download-master (operative download source per R71 §1.1).
# Regenerable: re-run runImageOps for any image whose ciphertext is missing.
data/encrypted_masters/

