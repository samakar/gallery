# Copy to .env at repo root before `npm run prisma:migrate`.
DATABASE_URL="file:./dev.db"
NODE_ENV=development
PORT=3000

# Integration secrets (placeholder; populate at integration time).
# PLATFORM_DEK=
# MAGIC_SECRET_KEY=sk_live_...        # server-side DID validation
# VITE_MAGIC_PUBLISHABLE_KEY=pk_live_... # client-side Magic init (Vite exposes VITE_* to the browser)
# VITE_MAGIC_PORTAL_URL=https://auth.magic.link/...  # per-app hosted reveal/settings URL from Magic dashboard; rendered as the "Open Magic to get my recovery key" button on /recovery-key. When unset the button is disabled with an inline error.
# STRIPE_SECRET_KEY=sk_test_...       # server-side Stripe API auth -- get from https://dashboard.stripe.com/test/apikeys
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...  # client-side Embedded Checkout init
# STRIPE_WEBHOOK_SECRET=whsec_...     # HMAC verification -- from `stripe listen --forward-to localhost:3000/v1/webhooks/stripe`
# ARWEAVE_JWK_BASE64=                 # base64 of an Arweave JWK; if missing, server generates one on startup and prints it for pasting back
# PLATFORM_DEK=                       # base64 of a 32-byte AES key for Master encryption; if missing, server generates and prints for pasting. NEVER rotate without a re-encrypt of all images.dek_wrapped values.
# CROSSMINT_API_KEY=
# CROSSMINT_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
