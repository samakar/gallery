# Copy to .env at repo root before `npm run prisma:migrate`.
DATABASE_URL="file:./dev.db"
NODE_ENV=development
PORT=3000

# Integration secrets (placeholder; populate at integration time).
# PLATFORM_DEK=
# MAGIC_SECRET_KEY=sk_live_...        # server-side DID validation
# VITE_MAGIC_PUBLISHABLE_KEY=pk_live_... # client-side Magic init (Vite exposes VITE_* to the browser)
# VITE_MAGIC_PORTAL_URL=https://auth.magic.link/...  # per-app hosted reveal/settings URL from Magic dashboard; rendered as the "Open Magic to get my recovery key" button on /recovery-key. When unset the button is disabled with an inline error.
# STRIPE_SECRET_KEY=sk_test_...       # server-side Stripe API auth -- get from https://dashboard.stripe.com/test/apikeys
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...  # client-side Embedded Checkout init
# STRIPE_WEBHOOK_SECRET=whsec_...     # HMAC verification -- from `stripe listen --forward-to localhost:3000/v1/webhooks/stripe`
# ARWEAVE_JWK_BASE64=                 # base64 of an Arweave JWK; if missing, server generates one on startup and prints it for pasting back
# PLATFORM_DEK=                       # base64 of a 32-byte AES key for Master encryption; if missing, server generates and prints for pasting. NEVER rotate without a re-encrypt of all images.dek_wrapped values.
# CROSSMINT_API_KEY=
# CROSSMINT_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# POSTMARK_TRANSACTIONAL_STREAM=outbound  # Postmark Stream ID (lowercase slug, not display name). New Postmark servers ship with the default transactional stream under the ID `outbound`. Override if you've archived `outbound` and created a custom stream.
# DEED_PROGRAM_ID=<base58 pubkey>  # Reserved address for the future deed-data PDA program (resale architecture). Used at MVP only to pre-compute deed_pda_address in the Arweave metadata JSON via findProgramAddressSync([b"deed-data", asset_id], DEED_PROGRAM_ID). Generate once with: node -e "const {Keypair}=require('@solana/web3.js');const bs58=require('bs58').default;const kp=Keypair.generate();console.log(kp.publicKey.toBase58(),bs58.encode(kp.secretKey));"

# Creator allowlist gate (identity.md §2.4). Launch-phase binary toggle controlling
# whether sign-cma requires an explicitly-listed email. Defaults to disabled.
# CREATOR_ALLOWLIST_ENABLED=false                          # `true` to block sign-cma unless email is in CREATOR_ALLOWLIST_EMAILS
# CREATOR_ALLOWLIST_EMAILS=                                # comma-separated email list; whitespace + case are normalized. Consulted only when CREATOR_ALLOWLIST_ENABLED=true.

# YouTube Data API v3 key (server-side, public data only -- distinct from the
# OAuth client used at sign-up). Used at Card 5 mint to fetch the
# creator_snapshot + video_snapshot blocks that get frozen into the deed's
# Arweave metadata JSON. Best-effort: if unset or unreachable, snapshots are
# null on the deed and a backfill sweeper can fill in later.
# YOUTUBE_DATA_API_KEY=
